{
  "agents": {
    "defaults": {
      "model": {
        "primary": "claude-sonnet-4-20250514",
        "fallbacks": [
          "claude-haiku-4-5-20251001"
        ]
      },
      "models": {
        "claude-sonnet-4-20250514": {},
        "claude-haiku-4-5-20251001": {}
      },
      "memorySearch": {
        "enabled": true
      },
      "sandbox": {
        "mode": "off"
      },
      "userTimezone": "America/New_York"
    },
    "list": [
      {
        "id": "ava",
        "workspace": "/data/workspace/ava",
        "model": {
          "primary": "claude-sonnet-4-20250514",
          "fallbacks": [
            "claude-haiku-4-5-20251001"
          ]
        }
      },
      {
        "id": "steve",
        "workspace": "/data/workspace/steve",
        "model": {
          "primary": "claude-sonnet-4-20250514",
          "fallbacks": [
            "claude-haiku-4-5-20251001"
          ]
        }
      },
      {
        "id": "tony",
        "workspace": "/data/workspace/tony",
        "model": {
          "primary": "claude-sonnet-4-20250514",
          "fallbacks": [
            "claude-haiku-4-5-20251001"
          ]
        }
      },
      {
        "id": "natasha",
        "workspace": "/data/workspace/natasha",
        "model": {
          "primary": "claude-sonnet-4-20250514",
          "fallbacks": [
            "claude-haiku-4-5-20251001"
          ]
        }
      },
      {
        "id": "jarvis",
        "workspace": "/data/workspace/jarvis",
        "model": {
          "primary": "claude-sonnet-4-20250514",
          "fallbacks": [
            "claude-haiku-4-5-20251001"
          ]
        }
      }
    ]
  },
  "tools": {
    "allow": [
      "*"
    ],
    "deny": [
      "group:runtime"
    ]
  },
  "bindings": [
    {
      "agentId": "${BOT_AGENT_ID}",
      "match": {
        "channel": "telegram"
      }
    }
  ],
  "session": {
    "dmScope": "per-account-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },
  "cron": {
    "enabled": true,
    "store": "/data/cron/jobs.json"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "streamMode": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": [
      "127.0.0.1"
    ]
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },
  "logging": {
    "level": "info"
  }
}
